<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studing.ex2.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <AnchorPane prefHeight="400.0" prefWidth="500.0">
         <children>
            <SplitPane dividerPositions="0.5" layoutX="30.0" layoutY="316.0" prefHeight="37.0" prefWidth="500.0">
              <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                     <children>
                        <Button id="decryptButton" fx:id="decryptButton" mnemonicParsing="false" onAction="#decrypt" prefHeight="35.0" prefWidth="246.0" text="Дешифрувати" textAlignment="CENTER" />
                     </children>
                  </AnchorPane>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                     <children>
                        <Button id="encryptButton" fx:id="encryptButton" mnemonicParsing="false" onAction="#encrypt" prefHeight="35.0" prefWidth="246.0" text="Зашифрувати" textAlignment="CENTER" />
                     </children>
                  </AnchorPane>
              </items>
            </SplitPane>
            <Label layoutX="94.0" layoutY="124.0" text="Зашифрований текст:">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Label layoutX="93.0" layoutY="73.0" text="Дешифрований текст:">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Label fx:id="decryptedField" layoutX="312.0" layoutY="73.0" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Label>
            <Label fx:id="encryptedField" layoutX="312.0" layoutY="124.0" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Label>
            <Label layoutX="143.0" layoutY="3.0" text="Текст в файлі:">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label fx:id="fileText" layoutX="280.0" layoutY="3.0">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
   </children>
</VBox>
